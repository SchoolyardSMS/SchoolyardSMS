# ==========================================
# 🏫 Schoolyard SMS - Environment Variables (Example)
# ==========================================

# 1. Base Application URLs 
# (Change to your production domain, e.g. https://yourschool.com)
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 2. Security 
# (Generate a strong 32+ character random string for production sessions cache validation)
NEXTAUTH_SECRET="your-nextauth-secret-here"

# 3. Database Connection
# (PostgreSQL URL format)
DATABASE_URL="postgresql://user:password@localhost:5432/schoolyard?schema=public"

# 4. Third-Party Integrations

# Resend API Key (for email sending)
RESEND_API_KEY="re_your_api_key_here"

# Google OAuth Credentials (for Parent/Student Sign-in)
# Obtain these from the Google Cloud Console
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email Configuration
RESEND_DOMAIN="your-domain.com"

# 5. Demo Mode Features
# Disable actual email sending (mocks links in console instead)
DISABLE_EMAILS="false"

# Disable actual file uploads (for Vercel serverless environment)
DISABLE_UPLOADS="false"
