generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  role           Role     @default(STUDENT)
  hashedPassword String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Role-specific profiles (One-to-One)
  studentProfile Student?
  teacherProfile Teacher?
  parentProfile  Parent?

  // Uploaded documents
  uploadedDocuments Document[] @relation("UploadedDocuments")
}

model Student {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOfBirth DateTime
  gradeLevel  Int

  enrollments Enrollment[]
  attendance  Attendance[]
  grades      Grade[]
  documents   Document[]      @relation("StudentDocuments")
  parents     ParentStudent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Parent {
  id     String  @id @default(cuid())
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone  String?

  children ParentStudent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ParentStudent {
  parentId  String
  parent    Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([parentId, studentId])
}

model Teacher {
  id         String  @id @default(cuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  department String?

  sections Section[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?
  credits     Float   @default(1.0)

  sections Section[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Section {
  id        String  @id @default(cuid())
  courseId  String
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  term      String // e.g., "Fall 2026"
  schedule  String // e.g., "Mon/Wed/Fri 10:00 AM"
  room      String?

  enrollments Enrollment[]
  assignments Assignment[]
  attendance  Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Enrollment {
  id        String           @id @default(cuid())
  studentId String
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sectionId String
  section   Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  status    EnrollmentStatus @default(ENROLLED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, sectionId])
}

enum EnrollmentStatus {
  ENROLLED
  DROPPED
  COMPLETED
}

model Assignment {
  id          String   @id @default(cuid())
  sectionId   String
  section     Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime
  maxScore    Float

  grades    Grade[]
  documents Document[] @relation("AssignmentDocuments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Grade {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  score        Float
  feedback     String?    @db.Text
  gradedAt     DateTime   @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assignmentId, studentId])
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sectionId String
  section   Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  date      DateTime         @db.Date
  status    AttendanceStatus
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, sectionId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  TARDY
  EXCUSED
}

model Document {
  id         String       @id @default(cuid())
  title      String
  fileUrl    String
  type       DocumentType
  uploaderId String
  uploader   User         @relation("UploadedDocuments", fields: [uploaderId], references: [id], onDelete: Cascade)

  // Optional relations contextualizing the document
  studentId    String?
  student      Student?    @relation("StudentDocuments", fields: [studentId], references: [id], onDelete: SetNull)
  assignmentId String?
  assignment   Assignment? @relation("AssignmentDocuments", fields: [assignmentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DocumentType {
  MEDICAL
  TRANSCRIPT
  ASSIGNMENT_SUBMISSION
  GENERAL
}
